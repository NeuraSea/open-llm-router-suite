# Copy this file to `.env.local` and replace placeholder values.
# Do not commit real secrets.

# Public example origins used in docs and compose.
ROUTER_PUBLIC_BASE_URL=https://router.example.com
NEWAPI_PUBLIC_BASE_URL=https://router.example.com
LIBRECHAT_PUBLIC_URL=/chat/
CASDOOR_ISSUER_URL=https://sso.example.com

# Router app. The ENTERPRISE_LLM_PROXY_ prefix is retained for v1 compatibility.
ENTERPRISE_LLM_PROXY_ROUTER_PUBLIC_BASE_URL=https://router.example.com/v1
ENTERPRISE_LLM_PROXY_SESSION_COOKIE_SECURE=true
ENTERPRISE_LLM_PROXY_SESSION_COOKIE_DOMAIN=.example.com
ENTERPRISE_LLM_PROXY_SSO_RETURN_TO_ALLOWED_HOSTS=["router.example.com","newapi.example.com"]
ENTERPRISE_LLM_PROXY_DATABASE_URL=postgresql+psycopg://router:router@127.0.0.1:55432/router

# Recommended: Casdoor or another OIDC provider. Casdoor can connect Feishu OAuth,
# corporate SSO providers, and WeChat QR login behind this single OIDC contract.
ENTERPRISE_LLM_PROXY_OIDC_AUTHORIZE_URL=https://sso.example.com/login/oauth/authorize
ENTERPRISE_LLM_PROXY_OIDC_TOKEN_URL=https://sso.example.com/api/login/oauth/access_token
ENTERPRISE_LLM_PROXY_OIDC_USERINFO_URL=https://sso.example.com/api/userinfo
ENTERPRISE_LLM_PROXY_OIDC_CLIENT_ID=router
ENTERPRISE_LLM_PROXY_OIDC_CLIENT_SECRET=replace_me
ENTERPRISE_LLM_PROXY_OIDC_REDIRECT_URI=https://router.example.com/auth/oidc/callback
ENTERPRISE_LLM_PROXY_OIDC_LOGIN_LABEL=Company SSO

# Optional direct Feishu OIDC preset. Use this only when you do not route Feishu
# through Casdoor.
ENTERPRISE_LLM_PROXY_FEISHU_CLIENT_ID=
ENTERPRISE_LLM_PROXY_FEISHU_CLIENT_SECRET=
ENTERPRISE_LLM_PROXY_FEISHU_REDIRECT_URI=https://router.example.com/auth/oidc/callback
ENTERPRISE_LLM_PROXY_FEISHU_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v2/oauth/token
ENTERPRISE_LLM_PROXY_FEISHU_USERINFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info

ENTERPRISE_LLM_PROXY_ADMIN_EMAILS=["admin@example.com"]
ENTERPRISE_LLM_PROXY_ADMIN_SUBJECTS=[]

# Router SSO signs short-lived identity assertions for New API.
# Generate an RSA keypair and set the private key for Router plus the public key
# for New API. Values may use literal \n escapes when stored on one line.
ENTERPRISE_LLM_PROXY_ROUTER_SSO_ISSUER=enterprise-llm-proxy
ENTERPRISE_LLM_PROXY_ROUTER_SSO_AUDIENCE=new-api
ENTERPRISE_LLM_PROXY_ROUTER_SSO_PRIVATE_KEY_PEM=replace_me
ROUTER_SSO_PUBLIC_KEY_PEM=replace_me
ROUTER_SSO_ISSUER=enterprise-llm-proxy
ROUTER_SSO_AUDIENCE=new-api
ROUTER_SSO_ENTERPRISE_GROUP=default

# New API integration. The admin token/user belong to New API and are used only
# by Router to create/update channels for imported upstream OAuth credentials.
ENTERPRISE_LLM_PROXY_NEWAPI_SYNC_ENABLED=true
ENTERPRISE_LLM_PROXY_NEWAPI_BASE_URL=http://new-api:3000
ENTERPRISE_LLM_PROXY_NEWAPI_ADMIN_ACCESS_TOKEN=replace_me
ENTERPRISE_LLM_PROXY_NEWAPI_ADMIN_USER_ID=1
ENTERPRISE_LLM_PROXY_NEWAPI_ENTERPRISE_GROUP=default
ENTERPRISE_LLM_PROXY_BRIDGE_BASE_URL_FOR_NEWAPI=http://app:8000
ENTERPRISE_LLM_PROXY_BRIDGE_UPSTREAM_API_KEY=replace_me
NEWAPI_SESSION_SECRET=replace_me

# LibreChat profile. Set strong random values before enabling
# `docker compose --profile librechat up --build`.
LIBRECHAT_DOMAIN_CLIENT=https://router.example.com/chat
LIBRECHAT_DOMAIN_SERVER=https://router.example.com/chat
LIBRECHAT_OPENID_CLIENT_ID=librechat
LIBRECHAT_OPENID_CLIENT_SECRET=replace_me
LIBRECHAT_CREDS_KEY=replace_me_32_byte_secret_value
LIBRECHAT_CREDS_IV=replace_me_16_bytes
LIBRECHAT_JWT_SECRET=replace_me
LIBRECHAT_JWT_REFRESH_SECRET=replace_me

# Optional database debugging.
# ENTERPRISE_LLM_PROXY_SQLALCHEMY_ECHO=false

# Optional: expose a host-machine LM Studio instance as a shared upstream.
# ENTERPRISE_LLM_PROXY_LM_STUDIO_ENABLED=true
# ENTERPRISE_LLM_PROXY_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
# ENTERPRISE_LLM_PROXY_LM_STUDIO_API_KEY=replace_me
# ENTERPRISE_LLM_PROXY_LM_STUDIO_ACCOUNT_ID=lm-studio
# ENTERPRISE_LLM_PROXY_LM_STUDIO_MAX_CONCURRENCY=1
